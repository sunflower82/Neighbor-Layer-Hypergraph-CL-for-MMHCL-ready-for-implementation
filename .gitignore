# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/

# Jupyter checkpoints
.ipynb_checkpoints/

# WandB
wandb/

# Experiment result folders at repo root (anchored with / to avoid matching data/baby/)
/Baby/
/Clothing/

# Large file exceeding GitHub 100MB limit - regenerated by load_data.py
data/baby/5-core/User_mat_rw.pth

# Other dataset folders not needed for Baby training
data/archive/
data/elec/
data/sports/
# Exclude large Clothing binaries but allow small JSON splits
data/Clothing/**/*.npy
data/Clothing/**/*.pth
data/Trained-Model*/
data/BM3*/
data/drive-download*/
data/data-*/

# Preprocessing-speedup patcher rollback artifacts (git history is the
# canonical rollback source). Patches in mmhcl_rev52_preprocessing_speedup/
# create *.bak_<patch> files next to the original; we never commit them.
*.bak_p1p2p5
*.bak_p6

# Orphan-prune (P3) auto-generated artifacts
data/**/_orig_backup/
data/**/remap_metadata.json
data/**/remap_id_maps.json
data/**/wema_*.pth
data/**/_stale/
